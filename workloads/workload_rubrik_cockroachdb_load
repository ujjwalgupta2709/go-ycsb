# Rubrik CockroachDB YCSB workload — LOAD phase
# Pre-populates tables before the run phase so reads are not wasted.
#
# Table weights (set in db.go when crdb.load_mode=true):
#   - sd.files        82%  → ~41,000,000 rows
#   - sd.event        12%  →  ~6,000,000 rows
#   - sd.event_series  4%  →  ~2,000,000 rows
#   - sd.report_stats  2%  →  ~1,000,000 rows
#

workload=core

recordcount=50000000
operationcount=50000000

# No QPS cap during load; use more threads for throughput
threadcount=100

# Pure insert, uniform distribution across key space
readproportion=0
updateproportion=0
insertproportion=1.0
deleteproportion=0
scanproportion=0
requestdistribution=uniform

measurementtype=histogram

# CockroachDB connection settings
crdb.hosts=127.0.0.1
crdb.port=26257
crdb.user=root
crdb.password=
crdb.db=sd
crdb.sslmode=require
crdb.load_mode=true
