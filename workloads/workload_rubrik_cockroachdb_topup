# Rubrik CockroachDB YCSB workload — TOP-UP phase
# Fills sd.event and sd.job_instance to match production row ratios.
#
# Target (production scaled to ~12M files baseline):
#   - sd.event        ~171K rows  (562K * 12M/39.2M)
#   - sd.job_instance  ~49K rows  (160K * 12M/39.2M)
#
# Keys start at 15000000 to avoid colliding with the initial 15M load.
# crdb.load_target_tables restricts inserts to only these two tables.

workload=core

recordcount=220000
operationcount=220000
insertstart=15000000

threadcount=50

# Pure insert, uniform distribution
readproportion=0
updateproportion=0
insertproportion=1.0
deleteproportion=0
scanproportion=0
requestdistribution=uniform

measurementtype=histogram

# CockroachDB connection settings
crdb.hosts=10.49.1.186,10.49.1.187,10.49.1.192,10.49.1.194
crdb.port=26257
crdb.user=root
crdb.password=
crdb.db=sd
crdb.sslmode=require
crdb.load_mode=true

# Restrict inserts to only these two tables (event 78%, job_instance 22% of their combined weight)
crdb.load_target_tables=sd.event,sd.job_instance
