# Rubrik Cassandra (cqlproxy) YCSB workload — RUN phase (PRODUCTION SPLIT)
# Issues mixed CQL queries against cqlproxy (port 27577).
# Targets files (89%) and report_stats (11%) — the tables served via CQL path.
#
# Run alongside workload_rubrik_cockroachdb_event_p75load at 300 QPS/node
# for a combined 1000 QPS/node matching production.
#
# Operation mix:
#   75% SELECT (point lookup), 20% SCAN (range, 10-100 rows), 2% INSERT, 2% UPDATE, 1% DELETE

workload=core

# Key space must match recordcount used in the load phase (50M total across all tables)
recordcount=50000000
operationcount=35000000

# 28 threads per node, 700 QPS/node
threadcount=28
target=700

# Operation mix matching production
readproportion=0.75
scanproportion=0.20
insertproportion=0.02
updateproportion=0.02
deleteproportion=0.01

# Uniform: every key equally likely — maximum cache pressure
requestdistribution=uniform

# Scan size: uniform between 10 and 100 rows per scan
maxscanlength=100
minscanlength=10
scanlengthdistribution=uniform

measurementtype=histogram

cassandra.hosts=127.0.0.1
cassandra.port=27577
cassandra.load_mode=false
cassandra.username=rksupport
# cassandra.password must be set per-node: cat /var/lib/rubrik/certs/cql_creds/rksupport
